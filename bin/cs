#!/usr/bin/env bash
# cs — управление аккаунтами Claude Code.
# https://github.com/Daniil-Sakharov/CS

set -u

SHARED_DIR="$HOME/.local/share/claude-shared"
ACCOUNTS_PREFIX="$HOME/.local/share/claude-"
TEMPLATE_SETTINGS="$SHARED_DIR/settings.template.json"
HOOK_SCRIPT="$SHARED_DIR/hooks/session-start.sh"
COMMANDS_DIR="$HOME/.claude/commands"
TMUX_SWITCH_DIR="$SHARED_DIR/tmux-switch"
CS_BIN="$HOME/.local/bin/cs"

RESERVED_NAMES=(add rm remove ls list current switch sw rename mv doctor help set-color shared launch pick import usage limits)

if [ -t 1 ]; then
  C_RESET=$'\033[0m'; C_BOLD=$'\033[1m'; C_DIM=$'\033[2m'
  C_RED=$'\033[31m'; C_GREEN=$'\033[32m'; C_YELLOW=$'\033[33m'
  C_BLUE=$'\033[34m'; C_MAGENTA=$'\033[35m'; C_CYAN=$'\033[36m'
else
  C_RESET=""; C_BOLD=""; C_DIM=""
  C_RED=""; C_GREEN=""; C_YELLOW=""
  C_BLUE=""; C_MAGENTA=""; C_CYAN=""
fi

default_color_for() {
  case "$1" in
    personal) echo cyan ;;
    work)     echo red ;;
    *)        echo "" ;;
  esac
}

die() { echo "${C_RED}cs: $*${C_RESET}" >&2; exit 1; }
log() { echo "${C_DIM}cs: $*${C_RESET}" >&2; }

# Portable mtime in seconds since epoch (Linux GNU stat / BSD macOS stat)
file_mtime() {
  local f="$1"
  stat -c %Y "$f" 2>/dev/null || stat -f %m "$f" 2>/dev/null || echo 0
}

validate_name() {
  local name="$1"
  [[ "$name" =~ ^[a-z][a-z0-9_-]*$ ]] || die "имя должно соответствовать ^[a-z][a-z0-9_-]*$ (получено: '$name')"
  for r in "${RESERVED_NAMES[@]}"; do
    [ "$name" = "$r" ] && die "имя '$name' зарезервировано"
  done
}

account_dir() { echo "$ACCOUNTS_PREFIX$1"; }

list_accounts() {
  local dir name
  shopt -s nullglob
  for dir in "$ACCOUNTS_PREFIX"*/; do
    [ -d "$dir" ] || continue
    name="${dir#$ACCOUNTS_PREFIX}"
    name="${name%/}"
    [ "$name" = "shared" ] && continue
    [[ "$name" == *.removed-* ]] && continue
    echo "$name"
  done
  shopt -u nullglob
}

current_account() {
  [ -z "${CLAUDE_CONFIG_DIR:-}" ] && return 1
  local name="${CLAUDE_CONFIG_DIR#$ACCOUNTS_PREFIX}"
  [ "$name" = "$CLAUDE_CONFIG_DIR" ] && return 1
  echo "$name"
}

get_color() {
  local name="$1" dir
  dir="$(account_dir "$name")"
  if [ -f "$dir/cs-color" ]; then
    cat "$dir/cs-color"; return
  fi
  local d; d="$(default_color_for "$name")"
  if [ -n "$d" ]; then
    echo "$d"; return
  fi
  local hash
  hash=$(printf '%s' "$name" | cksum | cut -d' ' -f1)
  local colors=(red green yellow blue magenta cyan)
  echo "${colors[$((hash % 6))]}"
}

set_color_internal() {
  local name="$1" color="$2"
  local valid=(red green yellow blue magenta cyan)
  local ok=0
  for c in "${valid[@]}"; do [ "$color" = "$c" ] && ok=1; done
  [ $ok -eq 0 ] && die "цвет должен быть один из: ${valid[*]}"
  local dir; dir="$(account_dir "$name")"
  [ -d "$dir" ] || die "аккаунт '$name' не существует"
  printf '%s' "$color" > "$dir/cs-color"
}

is_authed() {
  local cj="$(account_dir "$1")/.claude.json"
  [ -f "$cj" ] || return 1
  jq -e '(.oauthAccount // empty) != null or (.customApiKeyResponses // empty) != null' "$cj" >/dev/null 2>&1
}

last_used() {
  local f="$(account_dir "$1")/.claude.json"
  [ -f "$f" ] || { echo "—"; return; }
  local ts now diff
  ts=$(file_mtime "$f")
  now=$(date +%s)
  diff=$((now - ts))
  if [ $diff -lt 60 ]; then echo "только что"
  elif [ $diff -lt 3600 ]; then echo "$((diff/60))м назад"
  elif [ $diff -lt 86400 ]; then echo "$((diff/3600))ч назад"
  else echo "$((diff/86400))д назад"
  fi
}

ensure_shared_symlinks() {
  local dir="$1"
  local items=(projects sessions tasks file-history plans history.jsonl)
  mkdir -p "$SHARED_DIR/projects" "$SHARED_DIR/sessions" "$SHARED_DIR/tasks" \
           "$SHARED_DIR/file-history" "$SHARED_DIR/plans" "$TMUX_SWITCH_DIR"
  [ -e "$SHARED_DIR/history.jsonl" ] || touch "$SHARED_DIR/history.jsonl"

  local item
  for item in "${items[@]}"; do
    local target="$SHARED_DIR/$item"
    local link="$dir/$item"
    if [ -L "$link" ]; then
      local actual; actual="$(readlink "$link")"
      if [ "$actual" != "$target" ]; then
        log "перепривязываю $link → $target (было: $actual)"
        rm "$link"
        ln -s "$target" "$link"
      fi
    elif [ -e "$link" ]; then
      if [ -d "$link" ]; then
        log "сливаю $link в $target"
        if command -v rsync >/dev/null 2>&1; then
          rsync -a --ignore-existing "$link/" "$target/" 2>/dev/null || true
        else
          (cd "$link" && find . -type f -exec sh -c 'mkdir -p "$0/$(dirname "$1")"; [ -f "$0/$1" ] || cp "$1" "$0/$1"' "$target" {} \; 2>/dev/null) || true
        fi
        local backup="$link.local-$(date +%s)"
        mv "$link" "$backup"
        ln -s "$target" "$link"
        log "локальная копия → $backup"
      elif [ -f "$link" ]; then
        # Обычный файл (history.jsonl) — конкатенируем в shared, потом бэкап.
        if [ -s "$link" ]; then
          log "сливаю $link → $target (concat)"
          cat "$link" >> "$target" 2>/dev/null || true
        fi
        local backup="$link.local-$(date +%s)"
        mv "$link" "$backup"
        ln -s "$target" "$link"
        log "локальная копия → $backup"
      else
        local backup="$link.local-$(date +%s)"
        mv "$link" "$backup"
        ln -s "$target" "$link"
        log "локальная копия → $backup"
      fi
    else
      ln -s "$target" "$link"
    fi
  done

  mkdir -p "$COMMANDS_DIR"
  local clink="$dir/commands"
  if [ -L "$clink" ]; then
    local a; a="$(readlink "$clink")"
    if [ "$a" != "$COMMANDS_DIR" ]; then
      rm "$clink"
      ln -s "$COMMANDS_DIR" "$clink"
    fi
  elif [ ! -e "$clink" ]; then
    ln -s "$COMMANDS_DIR" "$clink"
  fi
}

ensure_settings() {
  local dir="$1"
  local f="$dir/settings.json"
  if [ ! -f "$f" ]; then
    cp "$TEMPLATE_SETTINGS" "$f"
  fi

  # 1) Hooks (SessionStart) — нужен для записи session_id в state-файл.
  if ! jq -e '.hooks.SessionStart' "$f" >/dev/null 2>&1; then
    local tmp; tmp="$(mktemp)"
    jq --slurpfile t "$TEMPLATE_SETTINGS" '. + {hooks: $t[0].hooks}' "$f" > "$tmp" && mv "$tmp" "$f"
    log "hooks добавлены в $f"
  fi

  # 2) Permissions.allow для cs binary — чтобы /cs ... в claude не дёргал
  #    permission-check на каждый вызов cs. Добавляем оба варианта (без и с
  #    аргументами) для совместимости разных версий claude.
  local p1="Bash($CS_BIN)" p2="Bash($CS_BIN *)"
  if ! jq -e --arg p "$p1" '(.permissions.allow // []) | index($p)' "$f" >/dev/null 2>&1 \
     || ! jq -e --arg p "$p2" '(.permissions.allow // []) | index($p)' "$f" >/dev/null 2>&1; then
    local tmp; tmp="$(mktemp)"
    jq --arg p1 "$p1" --arg p2 "$p2" \
       '.permissions.allow = ((.permissions.allow // []) + [$p1, $p2] | unique)' \
       "$f" > "$tmp" && mv "$tmp" "$f"
    log "cs-permission добавлен в $f"
  fi
}

sync_slash_commands() {
  mkdir -p "$COMMANDS_DIR"
  local accounts=()
  while IFS= read -r n; do accounts+=("$n"); done < <(list_accounts)

  local name
  for name in "${accounts[@]}"; do
    cat > "$COMMANDS_DIR/$name.md" <<EOF
---
description: Переключиться на аккаунт '$name' (продолжает текущую беседу)
---

!\`$CS_BIN switch $name\`
EOF
  done

  shopt -s nullglob
  local f cmd_name keep
  for f in "$COMMANDS_DIR"/*.md; do
    cmd_name="$(basename "$f" .md)"
    case "$cmd_name" in
      account|accounts|cs) continue;;
    esac
    if grep -q "$CS_BIN switch" "$f" 2>/dev/null; then
      keep=0
      for n in "${accounts[@]}"; do
        [ "$n" = "$cmd_name" ] && keep=1 && break
      done
      [ $keep -eq 0 ] && rm -f "$f"
    fi
  done
  shopt -u nullglob

  cat > "$COMMANDS_DIR/accounts.md" <<EOF
---
description: Показать все аккаунты Claude
---

!\`$CS_BIN ls\`
EOF

  cat > "$COMMANDS_DIR/account.md" <<EOF
---
description: Текущий аккаунт Claude
---

!\`$CS_BIN current --verbose\`
EOF

  cat > "$COMMANDS_DIR/cs.md" <<EOF
---
description: Управление аккаунтами Claude. Подкоманды — ls/current/add/rm/rename/import/set-color/doctor/usage/help
argument-hint: <ls|current|add|rm|rename|import|set-color|doctor|usage|help> [args]
---

!\`$CS_BIN \$ARGUMENTS\`
EOF

  # /usage не создаём отдельной слешкомандой — это нативная команда claude
  # для текущей сессии, не хотим её затирать. Лимиты по аккаунтам — через
  # /cs usage [args] (или из терминала: cs usage).
  rm -f "$COMMANDS_DIR/usage.md"
}

# ─── subcommands ──────────────────────────────────────────────────────────────

cmd_add() {
  local name="${1:-}"; shift || true
  [ -z "$name" ] && die "используй: cs add <name> [--copy-from <existing>]"
  validate_name "$name"
  local copy_from=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --copy-from) copy_from="${2:-}"; shift 2 || die "--copy-from требует значение";;
      *) die "неизвестный флаг: $1";;
    esac
  done

  local dir; dir="$(account_dir "$name")"
  [ -e "$dir" ] && die "аккаунт '$name' уже существует"

  mkdir -p "$dir"

  if [ -n "$copy_from" ]; then
    local src; src="$(account_dir "$copy_from")"
    [ -d "$src" ] || die "источник '$copy_from' не найден"
    [ -f "$src/settings.json" ] && cp "$src/settings.json" "$dir/settings.json" || cp "$TEMPLATE_SETTINGS" "$dir/settings.json"
    [ -f "$src/cs-color" ] && cp "$src/cs-color" "$dir/cs-color" || true
  else
    cp "$TEMPLATE_SETTINGS" "$dir/settings.json"
  fi

  ensure_shared_symlinks "$dir"
  ensure_settings "$dir"
  sync_slash_commands

  echo
  echo "${C_GREEN}✓${C_RESET} аккаунт '${C_BOLD}$name${C_RESET}' создан"
  echo "  путь: $dir"
  echo "  цвет: $(get_color "$name")"
  echo

  if [ -n "${TMUX:-}" ]; then
    echo "ты сейчас внутри tmux. чтобы залогиниться, открой ${C_BOLD}новый терминал${C_RESET} и выполни:"
    echo "  ${C_CYAN}cs $name${C_RESET}"
  else
    echo "запускаю ${C_CYAN}cs $name${C_RESET} для логина..."
    sleep 1
    exec "$CS_BIN" "$name"
  fi
}

cmd_rm() {
  local name="${1:-}" force=0
  shift || true
  [ -z "$name" ] && die "используй: cs rm <name> [-y]"
  while [ $# -gt 0 ]; do
    case "$1" in
      -y|--yes) force=1; shift;;
      *) die "неизвестный флаг: $1";;
    esac
  done

  local dir; dir="$(account_dir "$name")"
  [ -d "$dir" ] || die "аккаунт '$name' не существует"

  local cur; cur="$(current_account 2>/dev/null || true)"
  [ "$cur" = "$name" ] && die "'$name' — текущий активный аккаунт. сначала: cs switch <other>"

  if [ $force -eq 0 ]; then
    if [ -t 0 ]; then
      printf "удалить аккаунт '%s'? папка будет архивирована (y/N): " "$name"
      read -r ans
      case "$ans" in
        y|Y|yes|YES|Yes) ;;
        *) echo "отменено."; exit 0;;
      esac
    else
      die "не TTY — для удаления добавь -y: /cs rm $name -y  (папка будет архивирована, не удалена насовсем)"
    fi
  fi

  local archive="$dir.removed-$(date +%s)"
  mv "$dir" "$archive"
  rm -f "$COMMANDS_DIR/$name.md"
  sync_slash_commands
  echo "${C_GREEN}✓${C_RESET} аккаунт '$name' удалён"
  echo "  архив: $archive"
  echo "  откатить: mv '$archive' '$dir'"
}

cmd_ls() {
  local cur; cur="$(current_account 2>/dev/null || true)"
  printf "${C_BOLD}%2s %-15s %-50s %-6s %-15s %-8s${C_RESET}\n" "" "ИМЯ" "ПУТЬ" "AUTH" "ИСПОЛЬЗ." "ЦВЕТ"
  local name
  for name in $(list_accounts); do
    local dir; dir="$(account_dir "$name")"
    local marker=" "
    [ "$name" = "$cur" ] && marker="${C_CYAN}*${C_RESET}"
    local auth; is_authed "$name" && auth="${C_GREEN}✓${C_RESET}" || auth="${C_DIM}—${C_RESET}"
    local lu; lu="$(last_used "$name")"
    local color; color="$(get_color "$name")"
    printf " %b %-15s %-50s %b      %-15s %-8s\n" "$marker" "$name" "$dir" "$auth" "$lu" "$color"
  done
}

cmd_current() {
  local verbose=0
  [ "${1:-}" = "--verbose" ] || [ "${1:-}" = "-v" ] && verbose=1
  local cur
  if cur="$(current_account 2>/dev/null)"; then
    if [ $verbose -eq 1 ]; then
      echo "${C_BOLD}$cur${C_RESET}  (цвет: $(get_color "$cur"))"
      echo "CLAUDE_CONFIG_DIR=$CLAUDE_CONFIG_DIR"
    else
      echo "$cur"
    fi
  else
    echo "(none)"
    exit 1
  fi
}

cmd_switch() {
  local name="${1:-}"
  local explicit_sid="${2:-}"   # NEW: если передан — резюмим именно эту сессию,
                                 #  а cwd берём из её jsonl (поддерживает worktree)
  [ -z "$name" ] && die "используй: cs switch <name> [<session_id>]"
  local dir; dir="$(account_dir "$name")"
  [ -d "$dir" ] || die "аккаунт '$name' не существует. доступные: $(list_accounts | tr '\n' ' ')"

  if ! command -v tmux >/dev/null 2>&1; then
    die "cs switch требует tmux. установи tmux и попробуй снова. без tmux — cs $name --continue в новом терминале"
  fi
  [ -z "${TMUX:-}" ] && die "cs switch работает только внутри tmux (если просто открыть аккаунт — cs $name)"

  if [ "${CLAUDE_CONFIG_DIR:-}" = "$dir" ] && [ -z "$explicit_sid" ]; then
    echo "уже на '$name'"; exit 0
  fi

  local socket_path="${TMUX%%,*}"
  local socket_name; socket_name="$(basename "$socket_path")"

  local pane_id="${TMUX_PANE:-}"
  [ -z "$pane_id" ] && pane_id="$(tmux display -p '#{pane_id}' 2>/dev/null || true)"
  pane_id="${pane_id#%}"
  [ -z "$pane_id" ] && die "не удалось определить tmux pane_id"

  # ──────────────────────────────────────────────────────────────────────
  # МОДЕЛЬ:
  #   1. Без explicit_sid: «одна беседа, разные аккаунты». session_id из
  #      pane-keyed state-файла (один на pane/pwd, аккаунт в ключ не входит).
  #      Беседа продолжается, меняется только CLAUDE_CONFIG_DIR.
  #   2. С explicit_sid: переключаемся на КОНКРЕТНУЮ сессию (возможно из
  #      другого worktree). cwd берём из её jsonl, респавним pane туда.
  #
  #   State-файл живёт по пути:
  #     $TMUX_SWITCH_DIR/<socket>.p<pane>.<pwdhash>
  #   Hook (session-start.sh) перетирает его на каждый старт/ротацию sid.
  # ──────────────────────────────────────────────────────────────────────

  local target_pwd="$PWD"
  local session_id=""

  # ─── 1) Определяем session_id ────────────────────────────────────────
  if [ -n "$explicit_sid" ]; then
    if ! [[ "$explicit_sid" =~ ^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$ ]]; then
      die "session_id '$explicit_sid' не похож на UUID"
    fi
    session_id="$explicit_sid"
  else
    local pwd_hash; pwd_hash="$(printf '%s' "$PWD" | cksum | cut -d' ' -f1)"

    # Primary: pane-keyed state (новый формат, после миграции — единственный
    # источник истины). Содержит последний активный sid в этом pane/pwd.
    local pane_state="$TMUX_SWITCH_DIR/$socket_name.p$pane_id.$pwd_hash"
    [ -f "$pane_state" ] && session_id="$(cat "$pane_state" | tr -d '[:space:]')"

    # Legacy fallbacks — для state-файлов, оставшихся от старого формата
    # (per-account ключ). Срабатывают только если новый pane_state ещё не
    # записан (например, claude в этом pane стартовал ДО апгрейда и hook
    # с тех пор не вызывался). Hook на следующем старте/ротации перепишет
    # state в новый формат и почистит legacy-файлы.
    if [ -z "$session_id" ]; then
      local current_account=""
      if [ -n "${CLAUDE_CONFIG_DIR:-}" ]; then
        local _b; _b="$(basename "$CLAUDE_CONFIG_DIR")"
        case "$_b" in claude-*) current_account="${_b#claude-}" ;; esac
      fi
      if [ -n "$current_account" ]; then
        local cur_state="$TMUX_SWITCH_DIR/$socket_name.p$pane_id.$pwd_hash.$current_account"
        [ -f "$cur_state" ] && session_id="$(cat "$cur_state" | tr -d '[:space:]')"
        # Fallback по pane без учёта pwd_hash: ищем любой legacy state-файл
        # этого пэйна для $current_account (на случай если $PWD расходится
        # с тем, как claude закодировал project-папку — типичный кейс
        # worktree).
        if [ -z "$session_id" ]; then
          shopt -s nullglob
          local _f
          for _f in "$TMUX_SWITCH_DIR/$socket_name.p$pane_id."*."$current_account"; do
            [ -f "$_f" ] || continue
            # Паттерн p<pane>.<hash>.<account>, а не p<pane>.<account>.
            local _bn; _bn="${_f##*/}"
            local _suffix="${_bn#$socket_name.p$pane_id.}"
            case "$_suffix" in
              *.*) ;;     # содержит точку — формат с хэшем, ОК
              *) continue ;;  # без точки — старый <socket>.<account>, обработаем ниже
            esac
            session_id="$(cat "$_f" | tr -d '[:space:]')"
            [ -n "$session_id" ] && break
          done
          shopt -u nullglob
        fi
        # Very-old legacy: <socket>.<account>
        if [ -z "$session_id" ]; then
          local cur_legacy="$TMUX_SWITCH_DIR/$socket_name.$current_account"
          [ -f "$cur_legacy" ] && session_id="$(cat "$cur_legacy" | tr -d '[:space:]')"
        fi
      fi
    fi
  fi

  # ─── 2) Находим jsonl ВЕЗДЕ и достаём из него реальный cwd ─────────
  # Это критично для worktree-кейса: $PWD может не совпадать с тем, как
  # claude закодировал project-папку. Источник истины — сама jsonl.
  if [ -n "$session_id" ]; then
    local jsonl
    jsonl="$(find "$SHARED_DIR/projects" -name "${session_id}.jsonl" -type f -size +0 2>/dev/null | head -1)"
    if [ -z "$jsonl" ]; then
      log "session $session_id не найдена в projects/ — открываю fresh под '$name'"
      session_id=""
    else
      local extracted_cwd
      extracted_cwd="$(grep -m1 -oE '"cwd":"[^"]+"' "$jsonl" 2>/dev/null | sed 's/^"cwd":"//; s/"$//')"
      if [ -n "$extracted_cwd" ] && [ -d "$extracted_cwd" ]; then
        target_pwd="$extracted_cwd"
      elif [ -n "$extracted_cwd" ]; then
        if [ -n "$explicit_sid" ]; then
          die "cwd '$extracted_cwd' не существует (worktree удалён?)"
        else
          log "cwd '$extracted_cwd' не существует — открываю fresh под '$name'"
          session_id=""
        fi
      fi
    fi
  fi

  # ─── 3) Сохраняем state-файл для будущих back-switch ────────────────
  # Pane-keyed формат: <socket>.p<pane>.<pwdhash>. Аккаунт в ключ не
  # входит — после ротации sid'а внутри claude hook перетирает один
  # source-of-truth, и при любом следующем cs switch мы читаем актуальный
  # sid независимо от того, под каким аккаунтом он сейчас живёт.
  local target_pwd_hash; target_pwd_hash="$(printf '%s' "$target_pwd" | cksum | cut -d' ' -f1)"
  local target_state="$TMUX_SWITCH_DIR/$socket_name.p$pane_id.$target_pwd_hash"
  if [ -n "$session_id" ]; then
    printf '%s' "$session_id" > "$target_state"
    # Cleanup legacy per-account state-файлов для этого pane/pwd.
    # Глоб <target_state>.* ловит только legacy (новый файл без точки в конце).
    shopt -s nullglob
    local _legacy
    for _legacy in "$target_state."*; do
      [ -f "$_legacy" ] && rm -f "$_legacy"
    done
    shopt -u nullglob
  fi

  local color; color="$(get_color "$name")"
  tmux -L "$socket_name" set -g pane-active-border-style "fg=$color" 2>/dev/null || true
  tmux -L "$socket_name" set -g status-style "bg=$color,fg=black" 2>/dev/null || true

  printf '%s switch s=%s p=%s h=%s a=%s sid=%s pwd=%s\n' \
      "$(date +%s)" "$socket_name" "$pane_id" "$target_pwd_hash" "$name" "${session_id:-<fresh>}" "$target_pwd" \
      >> "$HOME/.local/share/claude-shared/cs.log" 2>/dev/null || true

  # ─── 4) Респавним pane: --dangerously-skip-permissions всегда ──────
  if [ -n "$session_id" ]; then
    exec tmux -L "$socket_name" respawn-pane -k -c "$target_pwd" \
      "env CLAUDE_CONFIG_DIR='$dir' claude --dangerously-skip-permissions --resume '$session_id'"
  else
    exec tmux -L "$socket_name" respawn-pane -k -c "$target_pwd" \
      "env CLAUDE_CONFIG_DIR='$dir' claude --dangerously-skip-permissions"
  fi
}

cmd_rename() {
  local old="${1:-}" new="${2:-}"
  { [ -z "$old" ] || [ -z "$new" ]; } && die "используй: cs rename <old> <new>"
  validate_name "$new"
  local odir ndir
  odir="$(account_dir "$old")"
  ndir="$(account_dir "$new")"
  [ -d "$odir" ] || die "аккаунт '$old' не существует"
  [ -e "$ndir" ] && die "аккаунт '$new' уже существует"
  local cur; cur="$(current_account 2>/dev/null || true)"
  [ "$cur" = "$old" ] && die "'$old' — текущий активный, переименование запрещено"
  mv "$odir" "$ndir"
  rm -f "$COMMANDS_DIR/$old.md"
  sync_slash_commands
  echo "${C_GREEN}✓${C_RESET} переименовано: $old → $new"
}

cmd_doctor() {
  echo "${C_BOLD}cs doctor${C_RESET}"

  echo
  echo "  ${C_BOLD}зависимости${C_RESET}"
  for tool in tmux jq; do
    if command -v "$tool" >/dev/null 2>&1; then
      echo "    ${C_GREEN}✓${C_RESET} $tool"
    else
      echo "    ${C_RED}✗${C_RESET} $tool ${C_DIM}(установи: brew install $tool / apt install $tool)${C_RESET}"
    fi
  done

  if [ ! -f "$HOOK_SCRIPT" ]; then
    echo "    ${C_RED}✗${C_RESET} hook-скрипт не найден: $HOOK_SCRIPT"
  else
    echo "    ${C_GREEN}✓${C_RESET} hook"
  fi

  if [ ! -f "$TEMPLATE_SETTINGS" ]; then
    echo "    ${C_RED}✗${C_RESET} шаблон settings не найден: $TEMPLATE_SETTINGS"
  else
    echo "    ${C_GREEN}✓${C_RESET} settings template"
  fi

  local name
  for name in $(list_accounts); do
    local dir; dir="$(account_dir "$name")"
    echo
    echo "  ${C_BOLD}$name${C_RESET}  $dir"
    ensure_shared_symlinks "$dir"
    ensure_settings "$dir"
    echo "    ${C_GREEN}✓${C_RESET} ok"
  done
  sync_slash_commands
  echo
  echo "${C_GREEN}✓${C_RESET} готово"
}

cmd_import() {
  local source_dir="" name="" mode="copy"
  while [ $# -gt 0 ]; do
    case "$1" in
      as|--as)
        [ -z "${2:-}" ] && die "as требует имя"
        name="$2"; shift 2 ;;
      --move) mode="move"; shift ;;
      --copy) mode="copy"; shift ;;
      -h|--help)
        cat <<'EOF'
cs import — импортировать существующий каталог Claude Code как cs-аккаунт.

использование:
  cs import [<source-dir>] [as <name>] [--copy|--move]

по умолчанию:
  source-dir = ~/.claude
  name       = default
  режим      = copy (исходник остаётся; --move перемещает projects/sessions/etc в shared/)

что копируется в claude-<name>/:
  .claude.json, settings.json, plugins/, cache/, stats-cache.json,
  mcp-needs-auth-cache.json, image-cache/, paste-cache/, backups/,
  shell-snapshots/, debug/, telemetry/, session-env/, teams/

что переносится в claude-shared/ (общее между аккаунтами):
  projects/, sessions/, tasks/, file-history/, plans/, history.jsonl
EOF
        return 0 ;;
      -*) die "неизвестный флаг: $1" ;;
      *)
        if [ -z "$source_dir" ]; then source_dir="$1"
        else die "лишний аргумент: $1"
        fi
        shift ;;
    esac
  done

  source_dir="${source_dir:-$HOME/.claude}"
  name="${name:-default}"
  validate_name "$name"

  [ -d "$source_dir" ] || die "источник '$source_dir' не существует"
  if [ ! -f "$source_dir/.claude.json" ] && [ ! -d "$source_dir/projects" ]; then
    die "'$source_dir' не похоже на каталог Claude Code (нет .claude.json и нет projects/)"
  fi

  local target_dir; target_dir="$(account_dir "$name")"
  [ -e "$target_dir" ] && die "аккаунт '$name' уже существует. укажи другое имя: cs import $source_dir as <other>"

  log "импортирую '$source_dir' как аккаунт '$name' (режим: $mode)"
  mkdir -p "$target_dir"

  # Per-account: копируем как есть. settings.json особо — туда добавим hooks.
  local per_account_items=(
    .claude.json
    plugins
    cache
    stats-cache.json
    mcp-needs-auth-cache.json
    image-cache
    paste-cache
    backups
    shell-snapshots
    debug
    telemetry
    session-env
    teams
    cs-color
  )
  local item
  for item in "${per_account_items[@]}"; do
    [ -e "$source_dir/$item" ] || continue
    cp -R "$source_dir/$item" "$target_dir/$item" 2>/dev/null || true
  done

  # settings.json — копируем и добавим hooks через ensure_settings.
  if [ -f "$source_dir/settings.json" ] && [ ! -L "$source_dir/settings.json" ]; then
    cp "$source_dir/settings.json" "$target_dir/settings.json"
  fi

  # Создать симлинки на shared/.
  ensure_shared_symlinks "$target_dir"

  # Перенести/скопировать данные projects/sessions/tasks/file-history/plans в shared/.
  # В режиме --move оригинал не удаляется через rm -rf (это могло бы потерять
  # файлы, которые rsync --ignore-existing пропустил из-за конфликта имён).
  # Вместо этого: переименовываем оригинал в .imported-<ts>, ставим симлинк.
  # Юзер сам удалит backup когда убедится что всё в порядке.
  local ts="$(date +%s)"
  local shared_items=(projects sessions tasks file-history plans)
  for item in "${shared_items[@]}"; do
    local src="$source_dir/$item"
    [ -e "$src" ] || continue
    if [ -L "$src" ]; then
      local actual; actual="$(readlink "$src")"
      [ "$actual" = "$SHARED_DIR/$item" ] && continue
    fi
    log "  $src → $SHARED_DIR/$item ($mode)"
    if command -v rsync >/dev/null 2>&1; then
      rsync -a --ignore-existing "$src/" "$SHARED_DIR/$item/" 2>/dev/null || true
    else
      cp -Rn "$src/." "$SHARED_DIR/$item/" 2>/dev/null || true
    fi
    if [ "$mode" = "move" ]; then
      local backup="$src.imported-$ts"
      mv "$src" "$backup"
      ln -s "$SHARED_DIR/$item" "$src"
      log "    оригинал: $backup (удали вручную когда убедишься: rm -rf $backup)"
    fi
  done

  # history.jsonl — конкатенация (могут быть дубликаты строк, но безопасно).
  if [ -f "$source_dir/history.jsonl" ] && [ ! -L "$source_dir/history.jsonl" ]; then
    log "  $source_dir/history.jsonl → $SHARED_DIR/history.jsonl ($mode)"
    if [ -s "$source_dir/history.jsonl" ]; then
      cat "$source_dir/history.jsonl" >> "$SHARED_DIR/history.jsonl" 2>/dev/null || true
    fi
    if [ "$mode" = "move" ]; then
      local backup="$source_dir/history.jsonl.imported-$ts"
      mv "$source_dir/history.jsonl" "$backup"
      ln -s "$SHARED_DIR/history.jsonl" "$source_dir/history.jsonl"
    fi
  fi

  ensure_settings "$target_dir"
  sync_slash_commands

  echo
  echo "${C_GREEN}✓${C_RESET} импортирован аккаунт '${C_BOLD}$name${C_RESET}'"
  echo "  путь:    $target_dir"
  echo "  цвет:    $(get_color "$name")"
  echo "  режим:   $mode"
  echo "  source:  $source_dir"
  if [ "$mode" = "copy" ]; then
    echo "  ${C_DIM}(оригинал не тронут — если cs не подойдёт, можно вернуться к нему)${C_RESET}"
  else
    echo "  ${C_DIM}(сессии перенесены в shared/, в исходнике остались симлинки)${C_RESET}"
  fi
  echo
  if [ -z "${TMUX:-}" ]; then
    echo "запустить: ${C_CYAN}cs $name${C_RESET}"
  else
    echo "переключиться: ${C_CYAN}cs switch $name${C_RESET}  ${C_DIM}или /$name${C_RESET}"
  fi
}

cmd_set_color() {
  local name="${1:-}" color="${2:-}"
  { [ -z "$name" ] || [ -z "$color" ]; } && die "используй: cs set-color <name> <red|green|yellow|blue|magenta|cyan>"
  set_color_internal "$name" "$color"
  echo "${C_GREEN}✓${C_RESET} цвет '$name' = $color"
}

cmd_help() {
  cat <<EOF
${C_BOLD}cs${C_RESET} — управление аккаунтами Claude Code
${C_DIM}https://github.com/Daniil-Sakharov/CS${C_RESET}

${C_BOLD}запуск:${C_RESET}
  cs <name> [args...]      запустить Claude под аккаунтом в tmux
  cs <name> <session_id>   запустить + резюмить указанную сессию (UUID)
  cs                       интерактивный выбор

${C_BOLD}внутри tmux/Claude:${C_RESET}
  cs <name>                переключить аккаунт в текущем pane
                           (= cs switch <name>, не падает с "уже внутри tmux")
  cs <name> <session_id>   переключить аккаунт + резюмить КОНКРЕТНУЮ сессию,
                           даже если она была в другом worktree (cwd авто-меняется)
  cs switch <name> [<sid>] то же что cs <name> [<sid>] из tmux
  /<name>                  переключить аккаунт (slash-команда)
  /cs <subcommand>         любая подкоманда из Claude
  /accounts                список аккаунтов
  /account                 текущий аккаунт
  /cs usage [<name>]       лимиты Claude (--all все, --refresh обойти кеш)
                           ${C_DIM}(нативный /usage остаётся claude'овским — для текущей сессии)${C_RESET}

${C_BOLD}управление:${C_RESET}
  cs ls                    список аккаунтов
  cs current               текущий
  cs add <name>            создать (с --copy-from <other>)
  cs import [<src>] [as <name>] [--copy|--move]
                           импортировать существующий ~/.claude/ как cs-аккаунт
  cs rm <name> [-y]        удалить (архивирует в .removed-<ts>)
  cs rename <old> <new>    переименовать
  cs set-color <name> <c>  цвет окна (red/green/yellow/blue/magenta/cyan)
  cs doctor                проверить зависимости и состояние
  cs usage [<name>]        лимиты Claude (текущий или конкретный аккаунт)
                           cs usage --all      — все аккаунты
                           cs usage --refresh  — обойти 10-мин кеш
  cs help                  эта справка
EOF
  echo
  echo "${C_BOLD}аккаунты:${C_RESET}"
  for name in $(list_accounts); do
    echo "  - $name ($(get_color "$name"))"
  done
}

cmd_launch() {
  local name="$1"; shift || true
  local dir; dir="$(account_dir "$name")"
  [ -d "$dir" ] || die "аккаунт '$name' не существует. cs add $name — чтобы создать"

  # Inside tmux: redirect to cmd_switch, optionally with explicit session_id.
  # Это даёт удобную команду:
  #   cs john              — переключить аккаунт в текущем pane (=cs switch john)
  #   cs john <session_id> — переключить + резюмить КОНКРЕТНУЮ сессию (другой worktree)
  if [ -n "${TMUX:-}" ]; then
    if [[ "${1:-}" =~ ^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$ ]]; then
      cmd_switch "$name" "$1"
    else
      cmd_switch "$name"
    fi
    return
  fi

  # Outside tmux: если передан session_id, нужно поднять tmux в правильном
  # worktree (cwd берём из jsonl сессии — поддерживает cs john <sid> из main
  # checkout'а для сессии, что жила в worktree).
  local launch_pwd="$PWD"
  if [[ "${1:-}" =~ ^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$ ]]; then
    local _sid="$1"
    local _jsonl
    _jsonl="$(find "$SHARED_DIR/projects" -name "${_sid}.jsonl" -type f -size +0 2>/dev/null | head -1)"
    [ -z "$_jsonl" ] && die "session $_sid не найдена в $SHARED_DIR/projects"
    local _cwd
    _cwd="$(grep -m1 -oE '"cwd":"[^"]+"' "$_jsonl" 2>/dev/null | sed 's/^"cwd":"//; s/"$//')"
    if [ -n "$_cwd" ] && [ -d "$_cwd" ]; then
      launch_pwd="$_cwd"
      log "сессия жила в $launch_pwd — поднимаю tmux там"
    elif [ -n "$_cwd" ]; then
      die "cwd '$_cwd' для сессии $_sid не существует (worktree удалён?)"
    fi
    set -- --resume "$@"
  fi

  if ! command -v tmux >/dev/null 2>&1; then
    log "tmux не установлен — запускаю claude напрямую"
    log "переключение между аккаунтами без перезапуска (cs switch) требует tmux"
    exec env CLAUDE_CONFIG_DIR="$dir" claude --dangerously-skip-permissions "$@"
  fi

  local sock="claude-$$"
  local color; color="$(get_color "$name")"

  local args_quoted=" --dangerously-skip-permissions"
  local a
  for a in "$@"; do
    args_quoted+=" $(printf '%q' "$a")"
  done

  tmux -L "$sock" new-session -d -s main -c "$launch_pwd" \
    "env CLAUDE_CONFIG_DIR='$dir' claude$args_quoted"
  tmux -L "$sock" set -g pane-active-border-style "fg=$color" 2>/dev/null || true
  tmux -L "$sock" set -g status-style "bg=$color,fg=black" 2>/dev/null || true
  exec tmux -L "$sock" attach -t main
}

cmd_pick() {
  local accounts=()
  while IFS= read -r n; do accounts+=("$n"); done < <(list_accounts)

  if [ ${#accounts[@]} -eq 0 ]; then
    echo "аккаунтов нет. создать первый: ${C_CYAN}cs add <name>${C_RESET}"
    exit 1
  fi
  if [ ${#accounts[@]} -eq 1 ]; then
    cmd_launch "${accounts[0]}"
    return
  fi

  echo "${C_BOLD}выбери аккаунт:${C_RESET}"
  local i=1 n
  for n in "${accounts[@]}"; do
    printf "  %d) %s ${C_DIM}(%s)${C_RESET}\n" "$i" "$n" "$(get_color "$n")"
    i=$((i+1))
  done
  printf "номер: "
  read -r choice
  local idx=$((choice - 1))
  { [ $idx -lt 0 ] || [ $idx -ge ${#accounts[@]} ]; } && die "неверный номер"
  cmd_launch "${accounts[$idx]}"
}

# ─── dispatcher ───────────────────────────────────────────────────────────────


cmd_doctor_v2() {
  echo "═══ cs health check (v2) ═══"
  echo ""

  echo "▸ Accounts:"
  local d n
  for d in "${ACCOUNTS_PREFIX}"*; do
    [ -d "$d" ] || continue
    n="$(basename "$d" | sed 's/^claude-//')"
    [ "$n" = "shared" ] && continue
    case "$n" in *.removed-*) continue ;; esac
    echo "  • $n → $d"
  done

  local total=0 valid=0 stale_jsonl=0 dead_socket=0 empty=0
  shopt -s nullglob
  local f fname socket pid sid
  for f in "$TMUX_SWITCH_DIR"/*; do
    [ -f "$f" ] || continue
    total=$((total+1))
    fname="$(basename "$f")"
    socket="${fname%%.*}"
    pid="${socket#claude-}"
    if ! kill -0 "$pid" 2>/dev/null; then
      dead_socket=$((dead_socket+1))
      continue
    fi
    sid="$(cat "$f" 2>/dev/null | tr -d '[:space:]')"
    if [ -z "$sid" ]; then
      empty=$((empty+1))
      continue
    fi
    if find "$SHARED_DIR/projects" -name "$sid.jsonl" -type f -size +0 2>/dev/null | head -1 | grep -q .; then
      valid=$((valid+1))
    else
      stale_jsonl=$((stale_jsonl+1))
    fi
  done
  shopt -u nullglob

  echo ""
  echo "▸ tmux-switch state files: $total"
  echo "  Valid:                 $valid"
  echo "  Dead socket (pid gone): $dead_socket"
  echo "  Empty:                 $empty"
  echo "  Stale jsonl missing:   $stale_jsonl"

  echo ""
  if [ $((dead_socket + empty + stale_jsonl)) -eq 0 ]; then
    echo "▸ Health: ${C_GREEN}OK${C_RESET}"
  else
    echo "▸ Health: $((dead_socket + empty + stale_jsonl)) stale — ${C_CYAN}cs doctor-v2 --prune${C_RESET} чтобы вычистить"
  fi
}

cmd_doctor_v2_prune() {
  local removed=0 kept=0
  shopt -s nullglob
  local f fname socket pid sid
  for f in "$TMUX_SWITCH_DIR"/*; do
    [ -f "$f" ] || continue
    fname="$(basename "$f")"
    socket="${fname%%.*}"
    pid="${socket#claude-}"
    if ! kill -0 "$pid" 2>/dev/null; then
      rm -f "$f"; removed=$((removed+1)); continue
    fi
    sid="$(cat "$f" 2>/dev/null | tr -d '[:space:]')"
    if [ -z "$sid" ]; then
      rm -f "$f"; removed=$((removed+1)); continue
    fi
    if find "$SHARED_DIR/projects" -name "$sid.jsonl" -type f -size +0 2>/dev/null | head -1 | grep -q .; then
      kept=$((kept+1))
    else
      rm -f "$f"; removed=$((removed+1))
    fi
  done
  shopt -u nullglob
  echo "  kept=$kept  removed=$removed"
}


cmd_usage() {
  local target_account="" force=0 show_all=0
  while [ $# -gt 0 ]; do
    case "$1" in
      -r|--refresh) force=1; shift ;;
      -a|--all)     show_all=1; shift ;;
      -h|--help)
        cat <<'EOF'
cs usage — показать недельные/сессионные лимиты Claude для аккаунта.

использование:
  cs usage                  # текущий аккаунт (CLAUDE_CONFIG_DIR)
  cs usage <name>           # конкретный аккаунт
  cs usage --all            # все аккаунты подряд
  cs usage --refresh        # игнорировать кеш (TTL 10 мин)

как работает:
  запускает `claude --print "/usage"` под нужным аккаунтом, кеширует
  результат в ~/.local/share/claude-shared/usage-cache/<account>.txt.
EOF
        return 0 ;;
      -*) die "неизвестный флаг: $1" ;;
      *)
        if [ -z "$target_account" ]; then target_account="$1"
        else die "лишний аргумент: $1"
        fi
        shift ;;
    esac
  done

  local accounts=()
  if [ "$show_all" -eq 1 ]; then
    while IFS= read -r n; do accounts+=("$n"); done < <(list_accounts)
    [ ${#accounts[@]} -eq 0 ] && die "аккаунтов нет"
  elif [ -n "$target_account" ]; then
    [ -d "$(account_dir "$target_account")" ] || die "аккаунт '$target_account' не существует"
    accounts=("$target_account")
  else
    local cur; cur="$(current_account 2>/dev/null || true)"
    [ -z "$cur" ] && die "не задан аккаунт и текущий не определён. cs usage <name> или cs usage --all"
    accounts=("$cur")
  fi

  local cache_dir="$SHARED_DIR/usage-cache"
  mkdir -p "$cache_dir"
  local ttl=600  # 10 минут

  local n
  for n in "${accounts[@]}"; do
    local dir; dir="$(account_dir "$n")"
    local cache_file="$cache_dir/$n.txt"
    local color; color="$(get_color "$n")"
    local now; now="$(date +%s)"
    local age=99999 from_cache=0
    if [ "$force" -eq 0 ] && [ -f "$cache_file" ]; then
      local cm; cm="$(file_mtime "$cache_file")"
      age=$((now - cm))
      [ "$age" -lt "$ttl" ] && from_cache=1
    fi

    echo
    echo "${C_BOLD}═══ $n ═══${C_RESET}  ${C_DIM}(цвет: $color)${C_RESET}"
    if [ "$from_cache" -eq 1 ]; then
      cat "$cache_file"
      echo "${C_DIM}(из кеша, age=${age}s — обновить: cs usage $n --refresh)${C_RESET}"
    else
      log "запрашиваю /usage у claude под '$n'..."
      local output rc
      output="$(env CLAUDE_CONFIG_DIR="$dir" claude --print --output-format text --permission-mode default "/usage" 2>&1)"
      rc=$?
      if [ $rc -ne 0 ]; then
        echo "${C_RED}не удалось получить usage (exit=$rc):${C_RESET}"
        echo "$output" | head -20
        continue
      fi
      printf '%s\n' "$output" > "$cache_file"
      echo "$output"
    fi
  done
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    doctor-v2|health)
      shift
      if [ "${1:-}" = "--prune" ]; then
        cmd_doctor_v2_prune
      else
        cmd_doctor_v2
      fi
      ;;
    "")             cmd_pick ;;
    add)            shift; cmd_add "$@" ;;
    rm|remove)      shift; cmd_rm "$@" ;;
    ls|list)        shift; cmd_ls "$@" ;;
    current)        shift; cmd_current "$@" ;;
    switch|sw)      shift; cmd_switch "$@" ;;
    rename|mv)      shift; cmd_rename "$@" ;;
    doctor)         shift; cmd_doctor "$@" ;;
    set-color)      shift; cmd_set_color "$@" ;;
    import)         shift; cmd_import "$@" ;;
    help|-h|--help) cmd_help ;;
    usage|limits)   shift; cmd_usage "$@" ;;
    *)
      local dir; dir="$(account_dir "$cmd")"
      if [ -d "$dir" ]; then
        cmd_launch "$@"
      else
        die "неизвестная команда или аккаунт: '$cmd'. cs help — справка"
      fi
      ;;
  esac
}

main "$@"
